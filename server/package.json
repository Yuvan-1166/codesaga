{
  "name": "codesaga-execution-server",
  "version": "1.0.0",
  "description": "Secure code execution service for CodeSaga",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:build": "docker build -t codesaga-node -f docker/node.Dockerfile . && docker build -t codesaga-python -f docker/python.Dockerfile .",
    "docker:clean": "docker system prune -f"
  },
  "keywords": ["code-execution", "sandbox", "docker"],
  "author": "CodeSaga",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.2",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.23",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
